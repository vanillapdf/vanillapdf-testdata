# Test data is binary — never normalize line endings, diff or merge it.
*.pdf  binary
*.PDF  binary
*.pfx  binary
*.p12  binary
*.cer  binary
*.der  binary

# Text metadata — LF everywhere, including on Windows checkouts.
*.json  text eol=lf
*.md    text eol=lf
*.py    text eol=lf
*.yml   text eol=lf

# Keep repository plumbing out of release archives.
.github/       export-ignore
.gitattributes export-ignore
.gitignore     export-ignore
